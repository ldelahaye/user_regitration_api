# =============================================================================
# Required
# =============================================================================

# Server-side secret for HMAC-hashed activation codes
APP_HMAC_SECRET=replace-with-a-random-secret

# =============================================================================
# Application
# =============================================================================

# Port the API listens on
APP_PORT=8000

# Enable debug mode
APP_DEBUG=false

# =============================================================================
# Database
# =============================================================================

# PostgreSQL connection URL
APP_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/registration

# Connection pool size
APP_DATABASE_MIN_POOL_SIZE=2
APP_DATABASE_MAX_POOL_SIZE=10

# =============================================================================
# Email
# =============================================================================

# When true, emails are logged to the console instead of sent
APP_EMAIL_MOCK=true

# Email service HTTP API endpoint
APP_EMAIL_API_URL=http://localhost:8025/api/v1/send

# Email service API key
APP_EMAIL_API_KEY=

# Sender address for outgoing emails
APP_EMAIL_FROM=noreply@registration.local

# =============================================================================
# Activation codes
# =============================================================================

# Code validity duration (minutes)
APP_ACTIVATION_CODE_TTL_MINUTES=1

# Max failed activation attempts before lockout
APP_ACTIVATION_MAX_ATTEMPTS=5

# =============================================================================
# Security
# =============================================================================

# bcrypt cost factor
APP_BCRYPT_ROUNDS=12

# =============================================================================
# Password policy (ANSSI R22 defaults)
# =============================================================================

# Minimum password length
APP_PASSWORD_MIN_LENGTH=12

# Maximum password length
APP_PASSWORD_MAX_LENGTH=128

# Character class requirements
APP_PASSWORD_REQUIRE_UPPERCASE=true
APP_PASSWORD_REQUIRE_LOWERCASE=true
APP_PASSWORD_REQUIRE_DIGIT=true
APP_PASSWORD_REQUIRE_SPECIAL=true
